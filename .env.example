# Copy this file to .env for local testing (never commit the real .env).
# In production these are set as GitHub Actions secrets and Render
# environment variables instead.

# --- Required: API-Football (api-sports.io) ---
API_FOOTBALL_KEY=your_api_football_key_here
# Only change this if you access API-Football via RapidAPI instead of
# directly through api-sports.io.
API_FOOTBALL_HOST=v3.football.api-sports.io

# --- Required: Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Any random string you choose — used to verify webhook calls really came
# from Telegram. Set the same value when you register the webhook.
TELEGRAM_WEBHOOK_SECRET=choose_a_random_secret_string

# --- Optional: Phase 2/3, leave blank to keep the bot fully free ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
